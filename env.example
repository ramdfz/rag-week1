# Meridian Health Partners RAG Chatbot - environment variables
# Copy this file to .env and fill in the placeholders. Never commit .env.

# --- Azure AI Foundry / Azure OpenAI-compatible endpoint ---
AZURE_OPENAI_ENDPOINT=https://ai-training-msftfoundry.openai.azure.com/openai/v1
AZURE_OPENAI_API_KEY=paste-your-azure-openai-api-key-here
AZURE_OPENAI_API_VERSION=2024-10-21

# Deployment names
GENERATION_DEPLOYMENT_PRIMARY=gpt-5.5
GENERATION_DEPLOYMENT_COMPARISON=DeepSeek-V3.2
EMBEDDING_DEPLOYMENT=text-embedding-3-large

# --- Azure AI Search ---
AZURE_SEARCH_ENDPOINT=https://your-search-resource-name.search.windows.net
AZURE_SEARCH_API_KEY=paste-your-search-admin-key-here
AZURE_SEARCH_INDEX_NAME=meridian-knowledge-base

# --- Local app config ---
DATABASE_URL=sqlite:///./meridian.db
API_KEY_AUTH_SECRET=generate-a-random-string-for-local-api-auth
VITE_API_BASE_URL=
VITE_API_KEY=use-the-same-local-development-secret-as-API_KEY_AUTH_SECRET

# --- Azure resource tagging / metadata ---
AZURE_RESOURCE_GROUP=AI_Training
AZURE_REGION=centralus
AZURE_OWNER_TAG=sriram_rampelli
